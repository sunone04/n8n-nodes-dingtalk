      ],
      "id": "56b2e18b-3110-4832-8aa7-9264abfd11a8",
      "name": "Sticky Note2"
    },
    {
      "parameters": {
        "content": "## TODO\n- 记录发票使用次数\n- 调用api进行发票验真",
        "height": 624,
        "color": 4
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        0,
        -336
      ],
      "id": "6c6f369d-84fa-48ef-a9e7-cc9aa31193ba",
      "name": "Sticky Note3"
    },
    {
      "parameters": {
        "jsCode": "// 依赖节点\nconst formItem = $(\"OA审批 获取单个审批实例详情\").first();\nconst aggItem  = $(\"汇总发票信息\").first();\n\nconst form = formItem?.json?.result || {};\nconst agg  = aggItem?.json || {};\nconst invoices = Array.isArray(agg.invoices) ? agg.invoices : [];\nconst summary  = agg.summary || {};\n\n// 取表单字段\nconst fcv = form.formComponentValues || [];\nconst getByName = (name) => (fcv.find(x => x.name === name) || {}).value || null;\n\nconst formTotalStr  = getByName('报销总额（元）') || '0';\nconst recordTimeStr = getByName('入账时间'); // 如 \"2025-10-28 15:29\"\n\n// 工具\nconst toNum = (v) => {\n  if (v == null || v === '') return 0;\n  if (typeof v === 'number') return v;\n  const n = parseFloat(String(v).replace(/[^\\d.\\-]/g,''));\n  return Number.isFinite(n) ? n : 0;\n};\nfunction parseDateOnly(s) {\n  if (!s) return null;\n  const t = String(s).trim().replace('年','-').replace('月','-').replace('日','');\n  const m = t.match(/(\\d{4})[-/.\\s](\\d{1,2})[-/.\\s](\\d{1,2})/);\n  if (!m) return null;\n  const [, y, mo, d] = m;\n  return new Date(`${y}-${String(mo).padStart(2,'0')}-${String(d).padStart(2,'0')}T00:00:00Z`);\n}\n\n// === 校验 A：发票合计必须 ≥ 报销总额（容差 0.01）===\nconst tol = 0.01;\nconst formTotal    = toNum(formTotalStr);\nconst invoiceTotal = toNum(summary.amount_with_tax);\nconst amountPass   = (invoiceTotal + tol) >= formTotal;\nconst shortfall    = Math.max(0, +(formTotal - invoiceTotal).toFixed(2)); // 发票少了多少（仅用于提示）\n\n// === 校验 B：开票日期 ≤ 入账日期 ===\nconst recordDate = parseDateOnly(recordTimeStr);\nlet datePass = true;\nconst lateList = [];\nif (recordDate) {\n  for (const inv of invoices) {\n    const d = parseDateOnly(inv?.issue_date);\n    if (!d) continue;\n    if (d.getTime() > recordDate.getTime()) {\n      datePass = false;\n      lateList.push(`${inv?.number || '未知票号'}(${inv?.issue_date || '无日期'})`);\n    }\n  }\n} else {\n  datePass = false;\n}\n\n// === 组装输出 ===\nconst reasons = [];\nif (!amountPass) reasons.push(`发票合计小于报销总额，差额¥${shortfall.toFixed(2)}`);\nif (!datePass) {\n  if (!recordDate) reasons.push('缺少入账时间');\n  else reasons.push(`存在发票开票日期晚于入账时间：${lateList.join('、')}`);\n}\n\nconst pass = reasons.length === 0;\nconst message = pass ? '校验通过' : `不通过：${reasons.join('；')}`;\n\nreturn [{ json: { pass, message } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
