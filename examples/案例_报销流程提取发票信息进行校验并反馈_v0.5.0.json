      "parameters": {
        "jsCode": "/***** 🔧 可修改的配置 *****/\nconst TABLE_NAME = '报销明细';                     // TableField 的 name\nconst ATT_LABEL_IN_ROW = '附件';                   // 行内“附件”字段的 label\n\n/***** 逻辑 *****/\nconst out = $input.all().map(({ json }) => {\n  const res = (json && json.result) || {};\n  const fcv = res.formComponentValues || [];\n\n  const tableNode = fcv.find(fc =>\n    fc.componentType === 'TableField' &&\n    (fc.name === TABLE_NAME)\n  );\n\n  let attachments = [];\n\n  if (tableNode && tableNode.value) {\n    // 钉钉 TableField.value 为 JSON 字符串\n    const rows = JSON.parse(tableNode.value || '[]');\n    for (const row of rows || []) {\n      const cells = Array.isArray(row.rowValue) ? row.rowValue : [];\n      const attCell = cells.find(v =>\n        v && (v.label === ATT_LABEL_IN_ROW)\n      );\n      if (attCell && Array.isArray(attCell.value)) {\n        attachments = attachments.concat(attCell.value); // 行内附件值为对象数组\n      }\n    }\n  }\n\n  return { json: { attachments } };\n});\n\nreturn out;"
      },
